# Production environment for docker/docker-compose.prod.yml.
#
# SETUP:
#   cp .env.prod.example .env.prod
#   Edit .env.prod — only the fields below are required.
#   make prod-up   (generates secrets automatically on first boot, then starts)
#
# AUTO-GENERATED (do not set these — make prod-up handles them via .secrets/secrets.env):
#   POSTGRES_PASSWORD, AUTH_SECRET, SCIM_BEARER_TOKEN, ACCESS_EVAL_TOKEN,
#   FLEET_WEBHOOK_SECRET, KC_ADMIN_PASSWORD, PROVISIONING_MASTER_KEY

# --- Public hostnames (must resolve to this host; Caddy gets TLS certs) ---
DASHBOARD_DOMAIN=app.example.com
API_DOMAIN=api.example.com
KC_DOMAIN=auth.example.com
# Full https:// URLs derived from the domains above.
DASHBOARD_PUBLIC_URL=https://app.example.com
API_PUBLIC_URL=https://api.example.com
KC_PUBLIC_URL=https://auth.example.com

# --- FleetDM (real instance, required) ---
FLEET_URL=https://fleet.example.com
FLEET_API_TOKEN=CHANGE_ME

# --- Keycloak posture-check SPI (optional) ---
# Set to "true" to enforce device posture at login. Requires Fleet enrollment.
POSTURE_CHECK_ENABLED=false

# --- Email notifications (optional) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_FROM=freecloud@example.com
# SMTP_TO=admin@example.com
# SMTP_PASSWORD=CHANGE_ME

# --- GeoIP for the geography access condition (optional) ---
# Host path to your own operator-downloaded MaxMind GeoLite2-Country.mmdb
# (or GeoLite2-City.mmdb). Unset (default) keeps geo conditions fail-closed —
# see docs/DEPLOYMENT.md "GeoIP (MaxMind GeoLite2)" for how to obtain one.
# GEOIP_MMDB_HOST_PATH=/etc/freecloud/GeoLite2-Country.mmdb
