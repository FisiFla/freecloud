# Production environment for docker/docker-compose.prod.yml.
# Copy to .env.prod, fill in real values, then:
#   docker compose -f docker/docker-compose.prod.yml --env-file .env.prod up -d --build
# Generate secrets with: openssl rand -base64 33

# --- Public hostnames (must resolve to this host; Caddy gets TLS certs for them) ---
DASHBOARD_DOMAIN=app.example.com
API_DOMAIN=api.example.com
KC_DOMAIN=auth.example.com
# Full https URLs derived from the domains above.
DASHBOARD_PUBLIC_URL=https://app.example.com
API_PUBLIC_URL=https://api.example.com
KC_PUBLIC_URL=https://auth.example.com

# --- Postgres ---
POSTGRES_USER=freecloud
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=freecloud

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME
KEYCLOAK_REALM=freecloud
# Backend service account (confidential client created by setup_realm.sh).
KEYCLOAK_CLIENT_ID=freecloud-service
KEYCLOAK_CLIENT_SECRET=CHANGE_ME
KEYCLOAK_AUDIENCE=freecloud-dashboard

# --- FleetDM (real instance) ---
FLEET_URL=https://fleet.example.com
FLEET_API_TOKEN=CHANGE_ME
# Shared secret the Fleet enrollment webhook signs callbacks with (HMAC-SHA256).
FLEET_WEBHOOK_SECRET=CHANGE_ME

# --- Service-to-service bearer tokens ---
# Dedicated token for inbound SCIM provisioning requests.
SCIM_BEARER_TOKEN=CHANGE_ME
# Dedicated token for Keycloak/access-gateway posture evaluation calls.
ACCESS_EVAL_TOKEN=CHANGE_ME

# --- A2/A3 (FCEX3-6/7): Keycloak posture-check SPI ---
# Internal URL the Keycloak SPI uses to reach the backend's posture endpoint.
# In prod the backend is reachable on the internal Docker network.
ACCESS_EVAL_URL=http://backend:8080/api/v1/access/evaluate
# Set to "true" to enable login enforcement; "false" leaves the SPI wired but dormant.
POSTURE_CHECK_ENABLED=false

# --- Frontend (Auth.js) ---
AUTH_SECRET=CHANGE_ME
AUTH_KEYCLOAK_ID=freecloud-dashboard
AUTH_KEYCLOAK_SECRET=CHANGE_ME

# --- Optional observability overlay ---
# Required when using docker/docker-compose.observability.yml.
GF_ADMIN_PASSWORD=CHANGE_ME
