{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" }
  ],
  "id": null,
  "uid": "freecloud-ops",
  "title": "FreeCloud — Operations",
  "description": "Request rate, latency, errors, DB pool, Keycloak/Fleet health, and reconciliation drift.",
  "tags": ["freecloud"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Request traffic",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request rate (req/s)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"freecloud-backend\"}[2m])) by (route)",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "5xx error rate (%)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"freecloud-backend\",status=~\"5..\"}[2m])) / sum(rate(http_requests_total{job=\"freecloud-backend\"}[2m]))",
          "legendFormat": "5xx rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Latency — P50 / P95 / P99 (s)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 9 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"freecloud-backend\"}[2m])) by (le))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"freecloud-backend\"}[2m])) by (le))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"freecloud-backend\"}[2m])) by (le))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Health checks",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Backend scrape",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 18 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" }, "0": { "text": "DOWN", "color": "red" } } }
          ]
        }
      },
      "targets": [
        {
          "expr": "up{job=\"freecloud-backend\"}",
          "legendFormat": "Backend",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Keycloak health",
      "description": "Based on /api/v1/health/keycloak response code",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 18 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "200": { "text": "OK", "color": "green" }, "503": { "text": "DOWN", "color": "red" } } }
          ]
        }
      },
      "targets": [
        {
          "expr": "http_requests_total{job=\"freecloud-backend\",route=\"/api/v1/health/keycloak\",status=\"200\"} > 0",
          "legendFormat": "last 200",
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "type": "stat",
      "title": "FleetDM health",
      "description": "Based on /api/v1/health/fleetdm response code",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 18 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "200": { "text": "OK", "color": "green" }, "503": { "text": "DOWN", "color": "red" } } }
          ]
        }
      },
      "targets": [
        {
          "expr": "http_requests_total{job=\"freecloud-backend\",route=\"/api/v1/health/fleetdm\",status=\"200\"} > 0",
          "legendFormat": "last 200",
          "refId": "A"
        }
      ]
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Readyz",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 18 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "200": { "text": "READY", "color": "green" }, "503": { "text": "NOT READY", "color": "red" } } }
          ]
        }
      },
      "targets": [
        {
          "expr": "http_requests_total{job=\"freecloud-backend\",route=\"/readyz\",status=\"200\"} > 0",
          "legendFormat": "Readyz",
          "refId": "A"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "Reconciliation drift",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 }
    },
    {
      "id": 21,
      "type": "gauge",
      "title": "Orphans in Keycloak (no DB record)",
      "description": "Users present in Keycloak but absent from the local database.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 23 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "freecloud_reconcile_orphans_in_keycloak",
          "legendFormat": "Orphans in Keycloak",
          "refId": "A"
        }
      ]
    },
    {
      "id": 22,
      "type": "gauge",
      "title": "Orphans in DB (no Keycloak record)",
      "description": "DB users that have no corresponding Keycloak account.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 23 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "freecloud_reconcile_orphans_in_db",
          "legendFormat": "Orphans in DB",
          "refId": "A"
        }
      ]
    },
    {
      "id": 23,
      "type": "stat",
      "title": "Last reconciliation run",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 23 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "dateTimeFromNow",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1800 },
              { "color": "red", "value": 3600 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "freecloud_reconcile_last_run_timestamp_seconds * 1000",
          "legendFormat": "Last run",
          "refId": "A"
        }
      ]
    }
  ]
}
