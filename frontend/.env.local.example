# In production this MUST be https:// — the app fails closed otherwise.
NEXT_PUBLIC_API_URL=http://localhost:8080
# Auth.js v5 uses the AUTH_ prefix convention.
AUTH_KEYCLOAK_ISSUER=http://localhost:8081/realms/freecloud
AUTH_KEYCLOAK_ID=freecloud-dashboard
AUTH_KEYCLOAK_SECRET=
# Dev placeholder only. Generate a real one for production: `openssl rand -base64 33`.
# The app refuses to start in production while AUTH_SECRET is this placeholder.
AUTH_SECRET=change-me-to-a-random-string
AUTH_URL=http://localhost:3000
