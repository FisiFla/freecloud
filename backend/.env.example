# APP_ENV gates configuration validation. Only "development" or "test" accept
# the insecure defaults below. ANY other value — including leaving APP_ENV unset
# — is treated as PRODUCTION and the server refuses to start until the default
# DB credentials, admin-cli client, missing secrets, etc. are replaced.
APP_ENV=development
PORT=8080
DATABASE_URL=postgres://freecloud:freecloud@localhost:5432/freecloud?sslmode=disable
KEYCLOAK_URL=http://localhost:8081
KEYCLOAK_REALM=freecloud
# Production MUST use a confidential client (e.g. freecloud-service), not admin-cli.
KEYCLOAK_CLIENT_ID=admin-cli
KEYCLOAK_CLIENT_SECRET=SET_ME
KEYCLOAK_AUDIENCE=freecloud-dashboard
# Development/test only. Allows X-Actor-ID fallback when JWT claims are absent.
# ALLOW_ACTOR_HEADER=false
FLEET_URL=http://localhost:8082
FLEET_API_TOKEN=SET_ME
# Shared secret used to authenticate Fleet enrollment-callback webhooks (HMAC-SHA256).
FLEET_WEBHOOK_SECRET=SET_ME
# Required in production: the dashboard origin allowed for CORS.
# CORS_ORIGIN=https://dashboard.example.com
